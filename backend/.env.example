# Environment Configuration for TV-Bridge
#
# Kopiere diese Datei zu .env und passe die Werte an.
# .env wird automatisch von pydantic-settings geladen.

# Datenbank-Pfad
TVBRIDGE_DB_PATH=/var/lib/tvbridge/tvbridge.db

# HID-Geräte
TVBRIDGE_HID_MOUSE_DEVICE=/dev/hidg0
TVBRIDGE_HID_KEYBOARD_DEVICE=/dev/hidg1

# Server-Konfiguration
TVBRIDGE_HOST=0.0.0.0
TVBRIDGE_PORT=8080

# Admin-Token (WICHTIG: Ändern in Production!)
# Generiere mit: python3 -c "import secrets; print(secrets.token_hex(32))"
TVBRIDGE_ADMIN_TOKEN=your-secure-admin-token-here

# Pairing-Timeout (Sekunden)
TVBRIDGE_PAIRING_TIMEOUT=120

# Rate Limiting
TVBRIDGE_AUTH_RATE_LIMIT=5
TVBRIDGE_INPUT_RATE_LIMIT=120

# WebSocket-Konfiguration
TVBRIDGE_WS_PING_INTERVAL=30
TVBRIDGE_WS_PING_TIMEOUT=60

# Log-Level
TVBRIDGE_LOG_LEVEL=INFO

# Optionale CORS (für Development mit separatem Frontend)
# TVBRIDGE_CORS_ORIGINS=http://localhost:3000,http://192.168.1.100:3000
